{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "_comment": "Sample SARIF 2.1.0 output produced by DeployGuard. Upload to GitHub Code Scanning via the upload-sarif action.",

  "runs": [
    {
      "tool": {
        "driver": {
          "name":           "DeployGuard",
          "version":        "1.0.0",
          "informationUri": "https://deployguard.dev",
          "rules": [
            {
              "id":   "SEC-001",
              "name": "HardcodedApiSecret",
              "shortDescription": {
                "text": "Hardcoded API Secret"
              },
              "fullDescription": {
                "text": "A secret or credential appears to be hardcoded directly in source code. Hardcoded secrets are permanently exposed once committed, even if later removed, because version control history preserves every change."
              },
              "helpUri": "https://deployguard.dev/rules/SEC-001",
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags":      ["security", "secrets", "deployguard"],
                "precision": "high",
                "security-severity": "9.5",
                "problem": { "severity": "error" }
              }
            },
            {
              "id":   "SEC-003",
              "name": "InsecureCORSConfiguration",
              "shortDescription": {
                "text": "Insecure CORS Configuration"
              },
              "fullDescription": {
                "text": "CORS is configured to allow all origins (*) with credentials enabled. This permits any website to make authenticated cross-origin requests to your API."
              },
              "helpUri": "https://deployguard.dev/rules/SEC-003",
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "tags":      ["security", "configuration", "deployguard"],
                "precision": "high",
                "security-severity": "7.5"
              }
            },
            {
              "id":   "SEC-006",
              "name": "DebugModeEnabled",
              "shortDescription": {
                "text": "Debug Mode Enabled"
              },
              "fullDescription": {
                "text": "A debug flag or configuration is enabled. Debug mode can expose stack traces, internal state, and verbose error messages to end users in production."
              },
              "helpUri": "https://deployguard.dev/rules/SEC-006",
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "tags":      ["security", "configuration", "deployguard"],
                "precision": "medium",
                "security-severity": "5.0"
              }
            }
          ]
        }
      },

      "results": [
        {
          "ruleId":  "SEC-001",
          "message": {
            "text": "Hardcoded API Secret. Move the secret to an environment variable and rotate the exposed credential immediately."
          },
          "level": "error",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri":       "src/lib/stripe.ts",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine":   4,
                  "startColumn": 22,
                  "endLine":     4,
                  "endColumn":   50
                }
              },
              "message": {
                "text": "const client = new Stripe(\"sk_live_abc123REDACTED\");"
              }
            }
          ],
          "partialFingerprints": {
            "deployguardFingerprint/v1": "SEC-001:src/lib/stripe.ts:4"
          },
          "properties": {
            "category": "secrets",
            "severity": "critical"
          }
        },
        {
          "ruleId":  "SEC-003",
          "message": {
            "text": "Insecure CORS Configuration. Restrict Access-Control-Allow-Origin to a known allowlist instead of '*'."
          },
          "level": "warning",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri":       "app/api/middleware.ts",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine":   18,
                  "startColumn": 3,
                  "endLine":     18,
                  "endColumn":   60
                }
              },
              "message": {
                "text": "res.setHeader(\"Access-Control-Allow-Origin\", \"*\");"
              }
            }
          ],
          "partialFingerprints": {
            "deployguardFingerprint/v1": "SEC-003:app/api/middleware.ts:18"
          },
          "properties": {
            "category": "security",
            "severity": "medium"
          }
        },
        {
          "ruleId":  "SEC-006",
          "message": {
            "text": "Debug Mode Enabled. Gate all debug flags behind a NODE_ENV !== 'production' check."
          },
          "level": "warning",
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri":       "next.config.ts",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine":   12,
                  "startColumn": 3,
                  "endLine":     12,
                  "endColumn":   25
                }
              },
              "message": {
                "text": "debug: true,"
              }
            }
          ],
          "partialFingerprints": {
            "deployguardFingerprint/v1": "SEC-006:next.config.ts:12"
          },
          "properties": {
            "category": "configuration",
            "severity": "medium"
          }
        }
      ],

      "artifacts": [
        {
          "location": { "uri": "src/lib/stripe.ts",      "uriBaseId": "%SRCROOT%" }
        },
        {
          "location": { "uri": "app/api/middleware.ts",  "uriBaseId": "%SRCROOT%" }
        },
        {
          "location": { "uri": "next.config.ts",         "uriBaseId": "%SRCROOT%" }
        }
      ]
    }
  ]
}
