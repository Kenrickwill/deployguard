generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(DEVELOPER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]
  scans    Scan[]
}

enum Role {
  ADMIN
  DEVELOPER
  VIEWER
}

model Project {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  repoUrl       String?
  defaultBranch String   @default("main")
  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  scans        Scan[]
  integrations Integration[]

  @@index([slug])
  @@index([ownerId])
}

model Scan {
  id          String      @id @default(cuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id])
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  branch      String?
  commitSha   String?
  environment Environment @default(STAGING)
  status      ScanStatus  @default(PENDING)
  startedAt   DateTime    @default(now())
  completedAt DateTime?
  scoreJson   Json?
  summaryJson Json?
  createdAt   DateTime    @default(now())

  findings Finding[]
  reports  Report[]

  @@index([projectId])
  @@index([status])
}

enum Environment {
  PRODUCTION
  STAGING
  DEVELOPMENT
}

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Finding {
  id            String          @id @default(cuid())
  scanId        String
  scan          Scan            @relation(fields: [scanId], references: [id])
  ruleId        String
  title         String
  description   String
  severity      Severity
  category      FindingCategory
  filePath      String?
  lineNumber    Int?
  snippet       String?
  remediation   String?
  references    String[]
  falsePositive Boolean         @default(false)
  notes         String?
  createdAt     DateTime        @default(now())

  @@index([scanId])
  @@index([severity])
  @@index([category])
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum FindingCategory {
  SECURITY
  PERFORMANCE
  RELIABILITY
  DEPENDENCY
  CONFIGURATION
  SECRETS
  COMPLIANCE
}

model Report {
  id        String       @id @default(cuid())
  scanId    String
  scan      Scan         @relation(fields: [scanId], references: [id])
  format    ReportFormat
  url       String?
  createdAt DateTime     @default(now())

  @@index([scanId])
}

enum ReportFormat {
  HTML
  PDF
  JSON
  MARKDOWN
}

model Integration {
  id        String          @id @default(cuid())
  projectId String
  project   Project         @relation(fields: [projectId], references: [id])
  type      IntegrationType
  name      String
  enabled   Boolean         @default(true)
  config    Json
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([projectId])
}

enum IntegrationType {
  GITHUB
  GITLAB
  BITBUCKET
  JIRA
  SLACK
  PAGERDUTY
}

model ScanRule {
  id          String          @id @default(cuid())
  ruleId      String          @unique
  title       String
  description String
  severity    Severity
  category    FindingCategory
  enabled     Boolean         @default(true)
  pattern     String?
  remediation String?
  references  String[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}
